# Example environment variables (DO NOT use real secrets here)
APP_URL=http://localhost:3010

# Postgres (required)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/mfcms

# Security (required)
SESSION_SECRET=change_me_to_a_random_32+_char_string
PASSWORD_PEPPER=change_me_to_a_random_string

# Local dev convenience
MFA_DISABLED=true

# Email (optional)
EMAIL_FROM=no-reply@example.com
RESEND_API_KEY=
SENDGRID_API_KEY=

# SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Object storage (optional; planned)
S3_BUCKET=
S3_REGION=

