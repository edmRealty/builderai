{
  "name": "mfcms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev -p 3010",
    "dev:no-deprecation": "NODE_OPTIONS=--no-deprecation next dev -p 3010",
    "dev:trace-deprecations": "NODE_OPTIONS=--trace-deprecation next dev -p 3010",
    "build": "next build",
    "start": "next start -p ${PORT:-3010}",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "node --env-file=.env scripts/seed.js",
    "test": "node --test"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.461.0",
    "next": "^15.1.12",
    "node-xlsx": "^0.24.0",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.6",
    "react-dom": "^19.0.6",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.12",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3"
  }
}
